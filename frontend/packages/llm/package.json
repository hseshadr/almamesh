{
  "name": "@almamesh/llm",
  "version": "0.0.1",
  "license": "MIT",
  "description": "In-browser, privacy-redacted OpenAI-compatible LLM narration for AlmaMesh (no backend)",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
