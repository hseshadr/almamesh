# =============================================================================
# AlmaMesh Web App - Environment Configuration
# =============================================================================
# Copy to .env and adjust values for your environment.
# NEVER commit .env files with real secrets to version control.
#
# IMPORTANT: Only variables prefixed with VITE_* are exposed to the browser.
# =============================================================================

# =============================================================================
# API CONFIGURATION (REQUIRED)
# =============================================================================

# Backend API URL
# Local development: http://localhost:8001/api/v1
# Production: https://api.almamesh.com/api/v1
VITE_API_URL=http://localhost:8001/api/v1

# =============================================================================
# AUTHENTICATION - Supabase (REQUIRED)
# =============================================================================
# Get from: https://supabase.com/dashboard -> Project Settings -> API

# Supabase project URL
VITE_SUPABASE_URL=http://localhost:54321

# Supabase anonymous/public key (safe for client-side)
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# =============================================================================
# BIRTH-LOCATION LOOKUP
# =============================================================================
# Fully offline: a bundled city database + tz-lookup resolve lat/lon and the
# IANA timezone with zero network calls. No geocoding API key is required.

# =============================================================================
# E2E TESTING (SET AUTOMATICALLY)
# =============================================================================
# Set to '1' to skip LLM interpretation during chart generation (faster tests).
# This is automatically set by Playwright config during E2E tests.
# VITE_E2E=1
