# =============================================================================
# AlmaMesh Web App — Environment Configuration
# =============================================================================
# AlmaMesh runs entirely in the browser, local-first: NO backend server, NO
# database, NO accounts/auth, and NO API keys are required to draw a chart.
# Charts are computed on-device (Pyodide/WASM); the only network traffic is the
# one-time signed-bundle download and any optional AI calls you opt into.
#
# As a result there is normally NOTHING to configure here — the app works with
# an empty (or absent) .env. EVERY variable below is OPTIONAL. To use one, copy
# this file to `.env` and uncomment it.
#
# IMPORTANT: Only variables prefixed with VITE_* are exposed to the browser.
# Never put a secret you don't want shipped to clients in a VITE_* variable.
# =============================================================================

# -----------------------------------------------------------------------------
# Optional AI interpretation + chat
# -----------------------------------------------------------------------------
# Interpretation/chat is OFF by default and can be configured at runtime in-app
# under Settings → AI. These variables let you PRE-CONFIGURE an OpenAI-compatible
# endpoint at build time instead. Drawing a chart never requires any of them.

# Base URL of an OpenAI-compatible endpoint.
#   Local default (no key needed): http://localhost:11434/v1  (Ollama)
#   Cloud example:                 https://openrouter.ai/api/v1
# VITE_LLM_API_BASE=http://localhost:11434/v1

# Model id used for interpretation/chat (e.g. an Ollama or OpenRouter model id).
# VITE_LLM_MODEL=

# API key — ONLY for a cloud endpoint; leave unset for a local model.
# VITE_LLM_API_KEY=

# Privacy posture. 'local_only' (default) fails closed for non-local endpoints;
# set 'cloud_premium' to allow PII-redacted calls to a configured cloud endpoint.
# VITE_LLM_PRIVACY_MODE=local_only

# -----------------------------------------------------------------------------
# Optional: signed-bundle base URL (advanced / custom deployments)
# -----------------------------------------------------------------------------
# Where the ed25519-signed engine bundle (DE421 ephemeris + wheels) is served
# from. Defaults to '/bundle' on the app's OWN origin; override only if you host
# the bundle elsewhere (e.g. a CDN).
# VITE_BUNDLE_BASE_URL=/bundle

# -----------------------------------------------------------------------------
# Internal: CI / exit-gate verification builds only — do NOT set manually.
# -----------------------------------------------------------------------------
# VITE_EXIT_GATE_HOOKS=1 installs test/observability hooks into the build. It is
# set automatically by the repo's verify-*.mjs gates and must NEVER be present
# in a normal production build.
# VITE_EXIT_GATE_HOOKS=1
