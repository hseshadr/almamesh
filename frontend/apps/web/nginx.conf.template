server {
  listen ${PORT};
  server_name _;

  root /usr/share/nginx/html;
  index index.html;

  # SPA routing: serve index.html for unknown paths (React Router)
  location / {
    try_files $uri $uri/ /index.html;
  }

  # Cache static assets aggressively (hashed bundles)
  location ~* \.(?:js|css|png|jpg|jpeg|gif|svg|ico|webp|woff|woff2|ttf|eot)$ {
    try_files $uri =404;
    expires 1y;
    add_header Cache-Control "public, immutable";
  }
}
