{
  "name": "@almamesh/web",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:cloud": "vite --mode dev",
    "dev:prod": "vite --mode prod",
    "build": "tsc -b && vite build",
    "build:dev": "tsc -b && vite build --mode dev",
    "build:prod": "tsc -b && vite build --mode prod",
    "preview": "vite preview",
    "serve": "bunx serve dist -l ${PORT:-3000}",
    "lint": "node ./node_modules/eslint/bin/eslint.js .",
    "typecheck": "tsc --noEmit",
    "test:e2e:ai": "playwright test --config=playwright.ai-settings.config.ts",
    "test:e2e:interp": "playwright test --config=playwright.interpretation.config.ts",
    "test:e2e:interp:real": "playwright test --config=playwright.interpretation.real.config.ts",
    "test:e2e:interp:heal:real": "playwright test --config=playwright.interpretation.heal.real.config.ts",
    "test:e2e:dashboard:agentic:real": "playwright test --config=playwright.dashboard.agentic.real.config.ts",
    "test:e2e:chat:rag:real": "playwright test --config=playwright.chat.rag.real.config.ts",
    "test:e2e:chat:grounding": "playwright test --config=playwright.chat.grounding.config.ts",
    "test:e2e:rectification": "playwright test --config=playwright.rectification.config.ts",
    "test:e2e:wizard": "playwright test --config=playwright.wizard-phase2.config.ts",
    "test:e2e:report:pdf": "playwright test --config=playwright.report-pdf.config.ts",
    "test:e2e:dual-voice": "playwright test --config=playwright.dual-voice-life-atlas.config.ts",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "data:cities": "node ../../scripts/generate-cities.mjs",
    "report:pdf:sample": "node --import tsx scripts/render-report-pdf.mjs"
  },
  "dependencies": {
    "@almamesh/browser": "workspace:*",
    "@almamesh/constants": "workspace:*",
    "@almamesh/llm": "workspace:*",
    "@almamesh/memory": "workspace:*",
    "@almamesh/shared-types": "workspace:*",
    "@almamesh/store": "workspace:*",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/hanken-grotesk": "^5.2.8",
    "@fontsource-variable/spline-sans-mono": "^5.2.8",
    "@huggingface/transformers": "^3.7.0",
    "@mui/material": "^7.3.6",
    "@mui/x-date-pickers": "^8.23.0",
    "@react-pdf/renderer": "^4.5.1",
    "@react-three/drei": "^10.0.0",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@tanstack/react-query": "^5.90.11",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.19",
    "framer-motion": "^12.23.26",
    "gsap": "^3.14.2",
    "i18next": "^26.3.1",
    "idb-keyval": "^6.2.1",
    "lucide-react": "^0.462.0",
    "postprocessing": "^6.39.1",
    "react": "^19.2.3",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.3",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.1.1",
    "rehype-sanitize": "^6.0.0",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.172.0",
    "tz-lookup": "6.1.25",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.49.1",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/react": "^16.3.1",
    "@testing-library/react-hooks": "^8.0.1",
    "@types/node": "^22.10.1",
    "@types/react": "^19.2.7",
    "@types/react-datepicker": "^7.0.0",
    "@types/react-dom": "^19.0.1",
    "@types/three": "^0.172.0",
    "@types/tz-lookup": "6.1.2",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.0.16",
    "all-the-cities": "3.1.0",
    "autoprefixer": "^10.4.20",
    "countries-list": "3.3.0",
    "eslint": "^9.16.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "happy-dom": "^20.0.11",
    "jsdom": "^27.4.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.0.16",
    "workbox-window": "^7.4.1"
  }
}
