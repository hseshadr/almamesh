# =============================================================================
# AlmaMesh Backend — Environment Configuration
# =============================================================================
# Copy to .env and adjust. Every key here maps to a field in
# src/almamesh/config.py (Settings). Unknown keys are ignored.
# NEVER commit a .env with real secrets.
#
# AlmaMesh is local-first: the chart engine runs on-device with no account,
# server, or database. The only config is the engine ephemeris + an optional
# LLM endpoint for interpretations.
# =============================================================================

# --- App -----------------------------------------------------------------
APP_NAME=AlmaMesh

# --- Engine --------------------------------------------------------------
# Ephemeris the publisher ships + records in bundle provenance. de440.bsp is
# the high-accuracy default; de421.bsp is smaller (~16MB) for browser delivery.
EPHEMERIS_FILE=de440.bsp

# --- LLM provider (optional — only needed for interpretations) -----------
# OpenRouter (recommended — access to many models). Get a key: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OpenAI (optional). Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Model selection, "provider/model-name" form (e.g. openrouter/deepseek/...).
LITELLM_CHAT_MODEL=openrouter/minimax/minimax-01
LITELLM_CHART_MODEL=openrouter/deepseek/deepseek-chat

# --- Local / pluggable LLM (optional) ------------------------------------
# Point AlmaMesh at ANY OpenAI-compatible endpoint: a local runtime
# (Ollama / LM Studio / llama.cpp-server), a self-hosted gateway, or a managed
# provider. When LLM_API_BASE is set, every interpretation, Q&A, and forecast
# call routes there. Leave unset to use the OpenRouter routing above.
#
# Run fully offline with Ollama:
#   ollama serve && ollama pull llama3.1
#   LLM_API_BASE=http://localhost:11434/v1
#   LLM_PRIVACY_MODE=local_only
#   LITELLM_CHAT_MODEL=openai/llama3.1
#   LITELLM_CHART_MODEL=openai/llama3.1
# LLM_API_BASE=http://localhost:11434/v1

# Data-egress contract for LLM calls (edge-proc PrivacyMode):
#   local_only    - FAIL CLOSED: refuse unless LLM_API_BASE is a loopback/private
#                   host, so chart data can never be sent to the cloud.
#   cloud_premium (default) - cloud providers allowed.
LLM_PRIVACY_MODE=cloud_premium
